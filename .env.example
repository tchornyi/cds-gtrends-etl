# Option A: full libpq connection string. Takes precedence when set.
DATABASE_URL=

# Option B: individual PostgreSQL settings. Used when DATABASE_URL is empty.
PGHOST=localhost
PGPORT=5432
PGDATABASE=google_trends
PGUSER=postgres
PGPASSWORD=postgres
PGSSLMODE=prefer

# Pipeline settings.
TRENDS_GEO=US
TRENDS_TOP_N=25
PRE_LOAD_SLEEP_SECONDS=20
